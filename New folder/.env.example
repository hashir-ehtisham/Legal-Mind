# ─── Supabase ───────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google Gemini ───────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIzaSy...

# ─── Gmail OAuth ─────────────────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
# Full setup guide: docs/GMAIL_SETUP.md
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# AES-256-GCM key for encrypting stored refresh tokens.
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit this value. If lost, all stored tokens are unreadable.
GMAIL_TOKEN_SECRET=64-char-hex-string-here

# ─── Security ────────────────────────────────────────────────────────────────
# Arbitrary secret used to protect cron endpoints from public access.
# Set the same value in Vercel Dashboard → Settings → Environment Variables
# AND in vercel.json cron headers (or pass as x-cron-secret header manually).
CRON_SECRET=generate-a-long-random-string-here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
